# ──────────────────────────────────────────────────
# HireIQ Backend – Environment Variable Reference
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to version control.
# ──────────────────────────────────────────────────

# ── Database ───────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/hireiq_db
DB_USERNAME=root
DB_PASSWORD=YOUR_DATABASE_PASSWORD

# ── Gemini AI ──────────────────────────────────────
GEMINI_API_KEY=YOUR_DATABASE_PASSWORD

